# Auto detect text files and ensure LF line endings
* text=auto eol=lf

# Explicitly declare text files
*.html text
*.css text
*.js text
*.json text
*.xml text
*.svg text
*.md text
*.txt text

# Declare binary files (no line ending conversion)
*.jpg binary
*.jpeg binary
*.png binary
*.gif binary
*.webp binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.pdf binary

# Large file tracking hint (use Git LFS for these)
# To enable: git lfs install && git lfs track "*.jpg" "*.png"
# *.jpg filter=lfs diff=lfs merge=lfs -text
# *.png filter=lfs diff=lfs merge=lfs -text
